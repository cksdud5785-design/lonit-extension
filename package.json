{
  "name": "lonit-product-collector",
  "version": "1.7.20",
  "private": true,
  "description": "Lonit source product collection and market sync Chrome extension (MV3)",
  "scripts": {
    "build": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/package.ps1",
    "version": "node tools/sync-version.mjs && git add manifest.json",
    "postversion": "npm run build",
    "release:patch": "npm version patch -m \"chore(ext): release v%s\"",
    "release:minor": "npm version minor -m \"chore(ext): release v%s\"",
    "publish:cws": "node tools/cws-publish.mjs"
  }
}
